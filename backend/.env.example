# Server
PORT=4000
NODE_ENV=development
APP_BASE_URL=http://localhost:5173
API_BASE_URL=http://localhost:4000

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=queuewise_user
DB_PASSWORD=changeme
DB_NAME=queuewise

# Auth secrets (generate long random strings for production)
JWT_SECRET=replace_with_a_long_random_string
MAGIC_LINK_SECRET=replace_with_another_long_random_string

# Email (magic links). In development, leave SMTP_HOST empty and
# links will be printed to the server console instead of emailed.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM="QueueWise <no-reply@queuewise.app>"

# Cookie
COOKIE_DOMAIN=localhost
